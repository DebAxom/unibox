<body>
    <h1>Me</h1>
    <button on:click="Logout()">Log Out</button>
</body>
<script>
    async function Logout() {
        const res = await fetch("http://localhost:5000/auth/logout", {
            method: "POST",
            credentials: "include",
            headers: {
                "Content-Type": "application/json"
            }
        });
        window.location.href = "/";
    }

</script>